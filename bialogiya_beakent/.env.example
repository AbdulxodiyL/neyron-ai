NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Gemini AI - lesson generation, chat, TTS narration, and real-time speaking
# practice all run on this ONE free-tier key. No OpenAI account needed.
GIMINI_AI_API_KEY=your-gemini-api-key-here
# Text-to-speech (story narration + explainer-video slides)
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
# Real-time speaking practice (WebSocket voice-to-voice via Gemini Live).
# Preview model names rotate - check https://ai.google.dev/gemini-api/docs/models
# if this one stops working.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# OpenAI is NOT required for any current feature. Only needed if you later
# re-enable the OpenAI-based TTS/Realtime code paths in src/services/ai/.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Voice cloning for story/explainer-video narration (optional - falls back to
# the default Gemini voice if not set). Needs a paid ElevenLabs plan (Starter+)
# since Instant Voice Cloning isn't on the free tier. Independent of the
# OpenAI/Gemini choice above - this is the only piece that still needs its
# own paid key if you want it.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

CLIENT_URL=https://your-frontend.onrender.com
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads/
